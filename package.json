{
  "name": "rowinbot.com",
  "version": "1.0.0",
  "description": "Rowin Hernandez personal website",
  "license": "GPL-3.0-only",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev:server": "node --inspect ./server.js",
    "content:watch": "node --watch --import ./content/builder/ts-node.register.mjs ./content/builder/content-builder.ts",
    "dev": "concurrently --kill-others-on-fail -n \"api,content\" -c \"auto\" \"npm run dev:server\" \"npm run content:watch\"",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "cross-env NODE_ENV=production node ./server.js",
    "typecheck": "react-router typegen && tsc",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@floating-ui/react": "0.27.13",
    "@iconify-icon/react": "^2.1.0",
    "@react-router/express": "7.6.3",
    "@react-router/fs-routes": "^7.6.3",
    "@react-router/node": "7.6.3",
    "@react-router/remix-routes-option-adapter": "^7.6.3",
    "@react-spring/web": "10.0.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@resvg/resvg-js": "^2.4.1",
    "@rollup/pluginutils": "^5.2.0",
    "@rowinbot/mdx-code-formatter": "^1.1.10",
    "@rowinbot/rollup-image-blur": "^1.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "clsx": "^1.2.1",
    "compression": "^1.7.4",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "dotenv": "^16.0.3",
    "esbuild": "^0.17.10",
    "express": "^4.19.2",
    "focus-trap": "^7.6.0",
    "framer-motion": "12.22.0",
    "isbot": "^4.1.0",
    "jotai": "^2.0.3",
    "mdx-bundler": "10.1.1",
    "morgan": "^1.10.0",
    "postprocessing": "^6.38.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router": "7.6.3",
    "rehype-autolink-headings": "^6.1.1",
    "rehype-slug": "^5.1.0",
    "satori": "^0.4.8",
    "sharp": "^0.34.2",
    "spin-delay": "^1.2.0",
    "tailwind-merge": "^2.5.5",
    "three": "^0.183.2",
    "tiny-invariant": "^1.3.1",
    "use-sound": "^4.0.3",
    "vite": "7.0.0",
    "vite-tsconfig-paths": "5.1.4",
    "watcher": "^2.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@react-router/dev": "^7.6.3",
    "@types/express": "^4.17.20",
    "@types/morgan": "^1.9.9",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@types/three": "^0.183.1",
    "chokidar": "^3.5.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "nodemon": "^2.0.21",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.38",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "ts-node": "10.9.2",
    "typescript": "^5.1.6",
    "typescript-eslint": "^8.63.0"
  },
  "engines": {
    "node": ">=24.3.0"
  }
}
